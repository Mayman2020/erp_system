## File: `docker-compose.yml`
```yaml
version: '3.9'
# Local / demo stack: PostgreSQL + backend + Angular (nginx).
# Start locally with:
#   docker compose up --build
# Frontend browser traffic is served on http://localhost and calls API at http://localhost:8080/api/v1.
services:
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-erp}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-erp}
      POSTGRES_DB: ${POSTGRES_DB:-erp}
    ports:
      - "5432:5432"
    volumes:
      - erp_pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-erp} -d ${POSTGRES_DB:-erp}"]
      interval: 5s
      timeout: 5s
      retries: 10

  backend:
    build:
      context: ./erp-system-backend
    depends_on:
      - postgres
    ports:
      - "8080:8080"
    environment:
      PORT: "8080"
      SPRING_PROFILES_ACTIVE: prod
      SPRING_DATASOURCE_URL: jdbc:postgresql://postgres:5432/${POSTGRES_DB:-erp}
      SPRING_DATASOURCE_USERNAME: ${POSTGRES_USER:-erp}
      SPRING_DATASOURCE_PASSWORD: ${POSTGRES_PASSWORD:-erp}
      JWT_SECRET: ${JWT_SECRET:-change-me-in-production-use-long-random-secret}

  frontend:
    build:
      context: ./erp-system-frontend
      args:
        NG_API_BASE_URL: http://localhost:8080/api/v1
    depends_on:
      - backend
    ports:
      - "80:80"

volumes:
  erp_pgdata:
```

