# Copy to .env and fill in (never commit .env).
# PostgreSQL (must match SPRING_* URLs in compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=erp_db

# Backend — required in production (no default in prod profile)
JWT_SECRET=

# CORS: default allow-all in compose (see application-prod). Set CORS_ALLOW_ALL=false for allowlist-only.
# CORS_ALLOW_ALL=true
# CORS_ALLOWED_ORIGINS=http://93.127.141.227:10026,http://93.127.141.227:10081

# Frontend image build: full API root including /api/v1 (browser calls this host:port)
# VPS example: UI on :10081, API on :10080
NG_API_BASE_URL=http://93.127.141.227:10080/api/v1

# Optional: override Hub images (docker-compose.prod.yml)
# BACKEND_IMAGE=mayman2020/erp-backend:latest
# FRONTEND_IMAGE=mayman2020/erp-frontend:latest

# Local build-and-push only (never commit real tokens): Docker Hub PAT
# DOCKERHUB_TOKEN=dckr_pat_...
