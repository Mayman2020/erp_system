# Copy to ops/environment/.env (or repo-root .env) before docker compose / production.
# Shared defaults reference: ../common/defaults.env.example

# PostgreSQL (must match SPRING_* URLs in compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=erp_db

# Backend — required in production (no default in prod profile)
JWT_SECRET=

# CORS (prod): set CORS_ALLOW_ALL=false and a strict allowlist
# CORS_ALLOW_ALL=false
# CORS_ALLOWED_ORIGINS=https://erp.example.com

# Optional mail (password-reset OTP). When disabled, OTP is logged at INFO in dev.
# MAIL_ENABLED=false
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@erp.example.com

# Frontend image build: full API root including /api/v1 (browser calls this host:port)
# VPS example: UI on :10081, API on :10080
NG_API_BASE_URL=http://93.127.141.227:10080/api/v1

# Optional: override Hub images (docker-compose.prod.yml)
# BACKEND_IMAGE=mayman2020/erp-backend:latest
# FRONTEND_IMAGE=mayman2020/erp-frontend:latest

# Local build-and-push only (never commit real tokens): Docker Hub PAT
# DOCKERHUB_TOKEN=dckr_pat_...
