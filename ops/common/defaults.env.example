# Shared reference for Docker Compose, frontend dev, and Hub builds (no secrets here).
# Copy values into ops/environment/.env — see ops/README.md

# --- Local Angular dev (npm start) → proxy to Spring Boot ---
# BACKEND_DEV_HOST=127.0.0.1
# BACKEND_DEV_PORT=8081

# --- Docker stack published ports (host) ---
# DOCKER_BACKEND_PUBLISH=10080
# DOCKER_FRONTEND_PUBLISH=10081

# --- Browser API root baked into production frontend image ---
# NG_API_BASE_URL=http://93.127.141.227:10080/api/v1
